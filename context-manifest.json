{
  "name": "context-repo-starter",
  "description": "Generic starter structure for onboarding AI agents with scoped, reviewable context.",
  "version": "0.1.0",
  "entrypoints": {
    "default": "00-start-here.md",
    "codex": "AGENTS.md",
    "claude_code": "CLAUDE.md"
  },
  "onboarding_paths": {
    "default": "agent-onboarding/default.md",
    "researcher": "agent-onboarding/researcher.md",
    "content_writer": "agent-onboarding/content-writer.md",
    "codebase_maintainer": "agent-onboarding/codebase-maintainer.md"
  },
  "sections": {
    "company": "company/README.md",
    "people": "people/README.md",
    "clients": "clients/README.md",
    "systems": "systems/README.md",
    "workflows": "workflows/README.md",
    "decisions": "decisions/README.md",
    "projects": "projects/README.md",
    "templates": "templates/",
    "examples": "examples/",
    "docs": "docs/",
    "publishing_checklist": "docs/publishing-checklist.md"
  },
  "confidence_labels": [
    "confirmed",
    "conflicting",
    "proposed",
    "unknown"
  ],
  "rules": [
    "Do not read every file by default.",
    "Follow the relevant onboarding path.",
    "Cite context files used.",
    "Treat examples as examples, not facts.",
    "Propose updates when context is missing or stale.",
    "Do not store secrets, credentials, raw exports, or private data in this repo."
  ]
}
